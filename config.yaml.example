# ============================================================
# Job Application Automation — config.yaml
# ============================================================
# Copy this file to config.yaml and fill in your details.
#   cp config.yaml.example config.yaml

# ============================================================
# Search Profiles — each profile targets different job families
# ============================================================
profiles:
  - name: "ML Engineer"
    target_job_titles:
      - "Machine Learning Engineer"
      - "ML Engineer"
      - "AI Engineer"
      - "AI/ML Engineer"
      - "ML Platform Engineer"
      - "MLOps Engineer"
      - "Deep Learning Engineer"
      - "Research Engineer"
      - "Applied ML"
      - "Machine Learning Scientist"
      - "Generative AI Engineer"
      - "LLM Engineer"
      - "AI Platform Engineer"
      - "AI Infrastructure Engineer"
    experience_levels: [Entry, Mid, Senior, Staff]
    max_years_required: 5
    min_match_score: 50

  - name: "Data Scientist"
    target_job_titles:
      - "Data Scientist"
      - "Applied Scientist"
      - "Research Scientist"
      - "Data Science"
      - "NLP Engineer"
      - "Computer Vision Engineer"
      - "Quantitative Researcher"
      - "Decision Scientist"
      - "AI Scientist"
      - "Applied AI Scientist"
      - "Machine Learning Scientist"
    experience_levels: [Entry, Mid, Senior, Staff]
    max_years_required: 5
    min_match_score: 45

  - name: "Data Engineer"
    target_job_titles:
      - "Data Engineer"
      - "Analytics Engineer"
      - "Platform Engineer"
      - "Data Infrastructure"
      - "Data Platform"
      - "Big Data Engineer"
      - "Data Platform Engineer"
      - "ETL Engineer"
      - "Streaming Engineer"
      - "Backend Data Engineer"
    experience_levels: [Entry, Mid, Senior]
    max_years_required: 5
    min_match_score: 45

# Target job titles (union of all profiles — used for global filtering/display)
target_job_titles:
  # ML Engineer
  - "Machine Learning Engineer"
  - "ML Engineer"
  - "AI Engineer"
  - "AI/ML Engineer"
  - "ML Platform Engineer"
  - "MLOps Engineer"
  - "Deep Learning Engineer"
  - "Research Engineer"
  - "Applied ML"
  - "Machine Learning Scientist"
  - "Generative AI Engineer"
  - "LLM Engineer"
  - "AI Platform Engineer"
  - "AI Infrastructure Engineer"
  # Data Scientist
  - "Data Scientist"
  - "Applied Scientist"
  - "Research Scientist"
  - "Data Science"
  - "NLP Engineer"
  - "Computer Vision Engineer"
  - "Quantitative Researcher"
  - "Decision Scientist"
  - "AI Scientist"
  - "Applied AI Scientist"
  # Data Engineer
  - "Data Engineer"
  - "Analytics Engineer"
  - "Platform Engineer"
  - "Data Infrastructure"
  - "Data Platform"
  - "Big Data Engineer"
  - "Data Platform Engineer"
  - "ETL Engineer"
  - "Streaming Engineer"
  - "Backend Data Engineer"

# Target locations — used for soft-filtering in match scoring
target_locations:
  - "Remote"
  - "Atlanta, GA"
  - "United States"

# Minimum match score (0–100) to appear in Top Matches sheet
min_match_score: 50

# Your actual years of professional experience.
# Used for resume-job matching (overrides auto-parsed value from PDF).
# Set to null to auto-detect from resume dates.
my_years_experience: 3

# Hard filter: skip any job whose description explicitly requires more than this many years.
# Set to null to disable.
max_years_required: 5

# Experience level filter — only keep jobs at these inferred levels.
# Leave empty [] to include all levels.
experience_levels:
  - Entry
  - Mid
  - Senior
  - Staff

# Keywords in job description that auto-disqualify a posting (case-insensitive)
exclude_keywords:
  - "6+ years"
  - "7+ years"
  - "8+ years"
  - "9+ years"
  - "10+ years"
  - "15+ years"
  - "20+ years"
  - "TS/SCI"
  - "Top Secret"
  - "Security Clearance"
  - "Clearance required"
  - "US Citizenship required"

# Max jobs to save per company per day (prevent one company flooding results)
max_jobs_per_company: 10

# Path to folder containing your resume files (PDF and DOCX supported)
resume_folder: "./resumes"

# Hours threshold — only jobs posted within this window are saved
hours_threshold: 24

# ============================================================
# Location Filters
# ============================================================
location_filter:
  usa_only: true                # Skip jobs outside USA
  allow_remote_worldwide: false # Set true to include Remote-Worldwide / Global remote jobs
  allow_unknown_location: true  # Set false to strictly drop ambiguous locations
  target_states: []             # Optional: e.g. [GA, NY, CA, TX] — empty = all US states

# ============================================================
# Output
# ============================================================
output_dir: "./output"
db_dir: "./db"

# ============================================================
# Logging
# ============================================================
log_level: "INFO"
log_file: "./logs/scraper.log"
company_updates_log: "./logs/company_updates.log"

# ============================================================
# Rate Limiting
# ============================================================
rate_limit:
  requests_per_second: 2
  min_delay_seconds: 0.5
  max_delay_seconds: 2.0

# ============================================================
# Scraper Settings
# ============================================================
scraper:
  timeout_seconds: 30
  max_retries: 3
  headless: true        # Playwright runs headless by default
  user_agent_rotation: true

# ============================================================
# Job Board APIs
# ============================================================
# Adzuna: free API — register at https://developer.adzuna.com
# Jooble:  free API — register at https://jooble.org/api/about
job_boards:
  adzuna_app_id:  ""   # paste your App ID here
  adzuna_app_key: ""   # paste your App Key here
  jooble_api_key: ""   # paste your API key here

# ============================================================
# Scraper agent (optional — merges search strings with target_job_titles)
# ============================================================
scraper_agent:
  # Extra or replacement search strings for JobSpy + Dice Apify actor
  # search_queries: []
  # JobSpy site ids (must be supported by python-jobspy)
  # Default JobSpy sites omit dice (often flaky in python-jobspy). Set jobspy_include_dice: true to add it.
  jobspy_sites:
    - linkedin
    - indeed
    - zip_recruiter
    - google
  # jobspy_include_dice: false   # default when jobspy_sites omitted; set true to append dice
  # Geographic search strings for JobSpy (falls back to target_locations if omitted)
  # locations:
  #   - "United States"
  #   - "Remote"
  #   - "Atlanta, GA"
  results_per_query: 30
  hours_old: 168                 # JobSpy recency window (hours)
  drop_jobs_without_posted_at: false  # set true for strict newest-only mode across all sources
  max_jobs_per_run: 500          # max listings sent to the LLM filter after dedupe + pre-rank
  jobspy_max_fetch_combos: 300   # cap on (search_query × location) JobSpy calls per run
  description_min_chars: 80      # listings shorter than this may get an HTTP backfill fetch
  description_backfill_max: 40   # max listing pages to fetch per run (time budget)
  # Optional runtime profile overrides for speed/cost:
  # runtime_profile: balanced    # fast | balanced | max
  # max_results_per_source: 200
  # max_apify_actor_runs: 40
  # ATS parallel scrape tuning (optional):
  # ats_max_workers: 6
  # ats_company_timeout_seconds: 35

  # Optional: extra Apify Store actors (requires APIFY_API_TOKEN). Each run calls
  # per search query. Do not add shahidirfan/dice-job-scraper here — Dice is built in.
  # Verify each actor's input schema in the Apify console; use {query}, {keyword}, {location} in strings.
  # Mappers: "dice" | "flex" (flex tries common title/company/url keys). Respect site ToS.
  # apify_actors:
  #   - id: your-username/some-job-actor
  #     enabled: false
  #     source_board: custom_board
  #     mapper: flex
  #     results_wanted: 25
  #     input:
  #       search: "{query}"
  #       location: "{location}"
  #
  # Example apify_actors (use actor IDs that exist in Apify Console — horizon_datajobs/* often 404):
  # apify_actors:
  #   - id: your-username/working-actor
  #     enabled: true
  #     source_board: custom
  #     mapper: flex
  #     results_wanted: 25
  #     input:
  #       query: "{query}"
  #       location: "{location}"
