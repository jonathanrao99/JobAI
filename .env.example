# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-public-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=your-openai-api-key

# Optional (defaults shown)
# REDIS_URL=redis://localhost:6379/0
# ENVIRONMENT=development

# Outreach contact enrichment (Apify primary, DB fallback when token missing)
# APIFY_API_TOKEN=your-apify-token
# APIFY_PEOPLE_ACTOR_ID=apify/google-search-scraper
# APIFY_EMAIL_ACTOR_ID=
# CONTACT_ENRICHMENT_MAX_CONTACTS=5
# CONTACT_ENRICHMENT_MIN_CONTACTS=3
# CONTACT_ENRICHMENT_EMAIL_TOP_K=3
# CONTACT_ENRICHMENT_CACHE_TTL_SECONDS=21600
# CONTACT_ENRICHMENT_FORCE_REFRESH=false
# SCRAPER_RUNTIME_PROFILE=balanced
# SCRAPER_MAX_RESULTS_PER_SOURCE=200
# SCRAPER_MAX_APIFY_ACTOR_RUNS=40

# Deployment — comma-separated origins for CORS
FRONTEND_URL=http://localhost:5173,https://your-app.vercel.app
BACKEND_URL=http://localhost:8000

# Frontend: call API directly (bypasses Next.js dev proxy). Use for long requests e.g. POST /api/applications/{id}/prepare.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# API auth — required when ENVIRONMENT=production; send as Authorization: Bearer … or X-JobAI-Token
# JOBAI_API_TOKEN=
# Frontend (Next) must match if token is set: NEXT_PUBLIC_JOBAI_API_TOKEN=same-value
# Optional model overrides
# Filter agent LLM parallelism (429 mitigation)
# FILTER_LLM_CONCURRENT_BATCHES=2
# FILTER_LLM_BATCH_STAGGER_MS=400

# OPENROUTER_MODEL=stepfun/step-3.5-flash:free
# OPENROUTER_FALLBACK_MODEL=nvidia/nemotron-3-super-120b-a12b:free

